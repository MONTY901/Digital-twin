const mongoose = require('mongoose');
const validator = require('validator');

const {
    validateAuthor,
    validatePartStatus,
    validateIssueDescription,
    validateRevisionDescription
} = require('./validation');

// 1. Part Schema: Represents a physical component in the Digital Twin
const partSchema = new mongoose.Schema({
    id: { type: Number, required: true, unique: true },
    status: { type: String, validate: validatePartStatus, default: 'Operational' },
    nextReview: { type: Date }
});

// 2. Review Schema: Historical logs of inspections
const reviewSchema = new mongoose.Schema({
    createdAt: { type: Date, default: Date.now },
    author: { type: String, required: true, validate: validateAuthor },
    passed: { type: Boolean, required: true },
    description: { type: String, validate: validateRevisionDescription },
    partId: { type: Number, required: true }
});

// 3. Issue Schema: Spatial markers for VR/AR visualization
const issueSchema = new mongoose.Schema({
    createdAt: { type: Date, default: Date.now },
    author: { type: String, required: true, validate: validateAuthor },
    text: { type: String, required: true, validate: validateIssueDescription },
    img: { 
        type: String, 
        validate: value => validator.isURL(value) && value.length < 256 
    },
    // Coordinate system for Unity VR integration
    x: { type: Number, required: true },
    y: { type: Number, required: true },
    z: { type: Number, required: true },
    partId: { type: Number, required: true }
});

module.exports = {
    Part: mongoose.model('Part', partSchema),
    Review: mongoose.model('Review', reviewSchema),
    Issue: mongoose.model('Issue', issueSchema)
};

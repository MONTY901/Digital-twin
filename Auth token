const express = require('express');
const { AuthenticationClient } = require('autodesk-forge-tools');

const router = express.Router();

// Initialize auth client
const authClient = new AuthenticationClient(
    process.env.FORGE_CLIENT_ID,
    process.env.FORGE_CLIENT_SECRET
);

// In-memory token cache
let cachedToken = null;
let tokenExpiry = null;

// Function to get token (with caching)
async function getAccessToken() {
    const now = Date.now();

    // If token exists and not expired, reuse it
    if (cachedToken && tokenExpiry && now < tokenExpiry) {
        return cachedToken;
    }

    // Otherwise fetch new token
    const response = await authClient.authenticate(['viewables:read']);

    cachedToken = response.access_token || response;
    tokenExpiry = now + (response.expires_in * 1000) - 60000; // refresh 1 min early

    return cachedToken;
}

// Route to get token
router.get('/token', async (req, res, next) => {
    try {
        const token = await getAccessToken();

        res.json({
            access_token: token,
            expires_at: tokenExpiry
        });
    } catch (error) {
        console.error('Auth Error:', error.message);
        res.status(500).json({ error: 'Failed to authenticate' });
    }
});

module.exports = router;
